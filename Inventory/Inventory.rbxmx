			<Properties>
				<ProtectedString name="Source"><![CDATA[if not game:IsLoaded() then game.Loaded:Wait() end

local function GetService(ServiceName)
	local Success, Service = pcall(game.GetService, game, ServiceName)

	while not Success or not Service do
		task.wait()
		Success, Service = pcall(game.GetService, game, ServiceName)
	end

	return Service
end

local function SafeCall(Function, ...)
	local Args = { ... }

	return xpcall(function()
		return Function(table.unpack(Args))
	end, function(Error)
		warn("[SafeCall Error]:", Error)
		warn(debug.traceback())
	end)
end

local Players = GetService("Players")
local UserInputService = GetService("UserInputService")
local StarterGui = GetService("StarterGui")
local TweenService = GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local InvGui = PlayerGui:WaitForChild("Inventory")
local UI = InvGui:WaitForChild("UI")

local InvUI = {
	Backpack = UI:WaitForChild("Backpack"),
	BackpackTools = UI:WaitForChild("Backpack"):WaitForChild("Tools"),
	BackpackTool = UI:WaitForChild("Backpack"):WaitForChild("Tools"):WaitForChild("Tool"),

	Hotbar = UI:WaitForChild("Hotbar"),
	HotbarSlot = UI:WaitForChild("Hotbar"):WaitForChild("Slot"),

	TopbarStandard = UI:WaitForChild("TopbarStandard")
}

local TopbarStandard = PlayerGui:WaitForChild("TopbarStandard")

SafeCall(function()
	StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, false)
end)

local function IsMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled and not UserInputService.MouseEnabled
end

local EquippedTool = nil
local ToolOrder = {}
local HotbarSlots = {}
local BackpackSlots = {}

local MaxHotbarSlots = IsMobile() and 5 or 10

InvUI.Hotbar.Size = IsMobile() and UDim2.fromScale(0.25, 0.05) or UDim2.fromScale(0.5, 0.1)

InvUI.Backpack.AnchorPoint = Vector2.new(0.5, 1)

task.wait()

local hotbarY = InvUI.Hotbar.AbsolutePosition.Y

local OPEN_POS = UDim2.fromOffset(InvUI.Hotbar.AbsolutePosition.X + InvUI.Hotbar.AbsoluteSize.X / 2, hotbarY - 6)

local CLOSED_POS = UDim2.fromOffset(OPEN_POS.X.Offset, OPEN_POS.Y.Offset - 20)

InvUI.Backpack.Position = CLOSED_POS

InvUI.Backpack.Size = IsMobile() and UDim2.fromScale(0.6, 0.9) or UDim2.fromScale(0.3, 0.5)

local BackpackOpen = false

local Tween1, Tween2, Tween3

local function SetBackpack(State)
	BackpackOpen = State

	if Tween1 then Tween1:Cancel() end
	if Tween2 then Tween2:Cancel() end
	if Tween3 then Tween3:Cancel() end

	local Stroke = InvUI.Backpack:FindFirstChild("Stroke")

	if State then
		InvUI.Backpack.Visible = true
		InvUI.Backpack.Position = CLOSED_POS
		InvUI.Backpack.GroupTransparency = 1

		if Stroke then Stroke.Transparency = 1 end

		Tween1 = TweenService:Create(InvUI.Backpack, TweenInfo.new(0.2), {
			Position = OPEN_POS
		})

		Tween2 = TweenService:Create(InvUI.Backpack, TweenInfo.new(0.2), {
			GroupTransparency = 0
		})

		Tween3 = Stroke and TweenService:Create(Stroke, TweenInfo.new(0.2), {
			Transparency = 0.2
		}) or nil

		Tween1:Play()
		Tween2:Play()

		if Tween3 then Tween3:Play() end
	else
		Tween1 = TweenService:Create(InvUI.Backpack, TweenInfo.new(0.2), {
			Position = CLOSED_POS
		})

		Tween2 = TweenService:Create(InvUI.Backpack, TweenInfo.new(0.2), {
			GroupTransparency = 1
		})

		Tween3 = Stroke and TweenService:Create(Stroke, TweenInfo.new(0.2), {
			Transparency = 1
		}) or nil

		Tween1:Play()
		Tween2:Play()

		if Tween3 then Tween3:Play() end

		Tween1.Completed:Once(function()
			if not BackpackOpen then
				InvUI.Backpack.Visible = false
			end
		end)
	end
end

local function ToggleBackpack()
	SetBackpack(not BackpackOpen)
end

local TopbarIcon = InvUI.TopbarStandard:WaitForChild("Holders"):WaitForChild("Left"):WaitForChild("Inventory Topbar Icon")

TopbarIcon.Activated:Connect(ToggleBackpack)

if not TopbarStandard then
	InvUI.TopbarStandard.Parent = PlayerGui
	TopbarIcon.Visible = true
else
	TopbarIcon.Parent = TopbarStandard:WaitForChild("Holders"):WaitForChild("Left")
	TopbarIcon.Visible = true
end

local function GetOrderedTools()
	local OrderedTools = {}
	local Character = LocalPlayer.Character

	local function AddTool(Tool)
		if Tool:IsA("Tool") and not table.find(ToolOrder, Tool) then
			table.insert(ToolOrder, Tool)
		end
	end

	for _, Tool in ipairs(LocalPlayer:WaitForChild("Backpack"):GetChildren()) do
		AddTool(Tool)
	end

	if Character then
		for _, Tool in ipairs(Character:GetChildren()) do
			AddTool(Tool)
		end
	end

	for i = #ToolOrder, 1, -1 do
		local Tool = ToolOrder[i]

		if not Tool or not Tool.Parent then
			table.remove(ToolOrder, i)
		end
	end

	for _, Tool in ipairs(ToolOrder) do
		if Tool.Parent == LocalPlayer:WaitForChild("Backpack") or (Character and Tool.Parent == Character) then
			table.insert(OrderedTools, Tool)
		end
	end

	return OrderedTools
end

local function GetEquippedTool()
	local Character = LocalPlayer.Character

	if not Character then return nil end

	for _, v in ipairs(Character:GetChildren()) do
		if v:IsA("Tool") then
			return v
		end
	end

	return nil
end

local function UpdateSelection()
	local Tools = GetOrderedTools()

	for Index, Slot in ipairs(HotbarSlots) do
		local Stroke = Slot:FindFirstChild("SelectedStroke")

		if Stroke then
			Stroke.Enabled = (Tools[Index] == EquippedTool)
		end
	end
end

local function SyncEquipped()
	EquippedTool = GetEquippedTool()
	UpdateSelection()
end

local function EquipTool(Tool)
	if not Tool then return end

	local Character = LocalPlayer.Character

	if not Character then return end

	local Humanoid = Character:FindFirstChildOfClass("Humanoid")

	if not Humanoid then return end

	if EquippedTool == Tool then
		Humanoid:UnequipTools()
		EquippedTool = nil
	else
		Humanoid:EquipTool(Tool)
		EquippedTool = Tool
	end

	UpdateSelection()
end

local function ClearSlots()
	for _, Slot in ipairs(HotbarSlots) do
		Slot:Destroy()
	end

	for _, Data in ipairs(BackpackSlots) do
		if Data.Container then
			Data.Container:Destroy()
		end
	end

	table.clear(HotbarSlots)
	table.clear(BackpackSlots)
end

local function HighlightSlot(Slot)
	local Stroke = Slot:FindFirstChild("SelectedStroke")

	if Stroke then
		Stroke.Enabled = true

		task.delay(0.08, function()
			if Stroke then
				Stroke.Enabled = false
			end
		end)
	end
end

local function UpdateHotbarNumbers()
	for i, Slot in ipairs(HotbarSlots) do
		local NumberObject = Slot:FindFirstChild("Number")

		if NumberObject then
			if NumberObject:IsA("TextLabel") then
				NumberObject.Text = tostring(i)
			elseif NumberObject:IsA("IntValue") then
				NumberObject.Value = i
			end
		end
	end
end

local function BuildKeybinds()
	local Keys = {
		Enum.KeyCode.One,
		Enum.KeyCode.Two,
		Enum.KeyCode.Three,
		Enum.KeyCode.Four,
		Enum.KeyCode.Five,
		Enum.KeyCode.Six,
		Enum.KeyCode.Seven,
		Enum.KeyCode.Eight,
		Enum.KeyCode.Nine,
		Enum.KeyCode.Zero
	}

	UserInputService.InputBegan:Connect(function(Input, GameProcessed)
		if GameProcessed then return end

		for i, Key in ipairs(Keys) do
			if Input.KeyCode == Key then
				local Tools = GetOrderedTools()
				local Tool = Tools[i]

				if Tool then
					EquipTool(Tool)
				end
			end
		end
	end)
end

local RefreshInventory

RefreshInventory = function()
	ClearSlots()

	local Tools = GetOrderedTools()

	for Index, Tool in ipairs(Tools) do
		local IsHotbar = Index <= MaxHotbarSlots

		if IsHotbar then
			local Slot = InvUI.HotbarSlot:Clone()

			Slot.Visible = true
			Slot.Name = Tool.Name
			Slot.Parent = InvUI.Hotbar

			local Hitbox = Slot:FindFirstChild("Hitbox")
			local Display = Slot:FindFirstChild("Display")

			if Display then
				local IconImage = Display:FindFirstChild("Icon")
				local Label = Display:FindFirstChild("Label")

				local Texture = Tool.TextureId

				if Texture and Texture ~= "" then
					if IconImage then
						IconImage.Image = Texture
						IconImage.Visible = true
					end

					if Label then
						Label.Visible = false
					end
				else
					if IconImage then
						IconImage.Visible = false
					end

					if Label then
						Label.Visible = true
						Label.Text = Tool.Name
					end
				end
			end

			if Hitbox and Hitbox:IsA("GuiButton") then
				Hitbox.MouseButton1Click:Connect(function()
					EquipTool(Tool)
					HighlightSlot(Slot)
				end)
			end

			table.insert(HotbarSlots, Slot)
		else
			local ToolContainer = InvUI.BackpackTool:Clone()

			ToolContainer.Visible = true
			ToolContainer.Name = Tool.Name
			ToolContainer.Parent = InvUI.BackpackTools

			table.insert(BackpackSlots, {
				Container = ToolContainer,
				Button = ToolContainer,
				Tool = Tool
			})
		end
	end

	UpdateHotbarNumbers()
	SyncEquipped()
end

LocalPlayer:WaitForChild("Backpack").ChildAdded:Connect(function()
	task.defer(RefreshInventory)
	task.defer(SyncEquipped)
end)

LocalPlayer:WaitForChild("Backpack").ChildRemoved:Connect(function()
	task.defer(RefreshInventory)
	task.defer(SyncEquipped)
end)

LocalPlayer.CharacterAdded:Connect(function(Character)
	Character.ChildAdded:Connect(function()
		task.defer(SyncEquipped)
	end)

	Character.ChildRemoved:Connect(function()
		task.defer(SyncEquipped)
	end)

	task.defer(SyncEquipped)
end)

UserInputService.InputBegan:Connect(function(Input, GameProcessed)
	if GameProcessed then return end

	if Input.KeyCode == Enum.KeyCode.Backquote then
		ToggleBackpack()
	end
end)

BuildKeybinds()
RefreshInventory()]]></ProtectedString>
