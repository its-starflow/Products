		ContentPadding.Name = "ContentPadding"
		ContentPadding.PaddingTop = UDim.new(0, 4)
		ContentPadding.PaddingRight = UDim.new(0, 4)
		ContentPadding.PaddingLeft = UDim.new(0, 4)
		ContentPadding.PaddingBottom = UDim.new(0, 4)

		local ContentLayout = Instance.new("UIListLayout", ContentFrame)
		ContentLayout.Name = "ContentLayout"
		ContentLayout.HorizontalFlex = Enum.UIFlexAlignment.Fill
		ContentLayout.Padding = UDim.new(0, 4)
		ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder

		local function LoadHeadshot()
			Headshot.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. Player.UserId .. "&width=420&height=420&format=png"
		end
		task.spawn(LoadHeadshot)

		local UI_API = setmetatable({
			ScreenGui = ScreenGui,
			Aero = AeroFrame,
			HomePosition = AeroFrame.Position,
			ShowButton = Show,
			TitleLabel = TitleLabel,
			TabsFrame = TabsFrame,
			ContentFrame = ContentFrame,
			Tabs = {},
			TabContents = {},
			CurrentTab = nil
		}, UI_API_MT)

		local function OnAeroMoved(NewPosition)
			UI_API.HomePosition = NewPosition
		end

		SetDraggable(AeroFrame, OnAeroMoved)

		local HasMouse = UserInputService.MouseEnabled
		local HasKeyboard = UserInputService.KeyboardEnabled

		if HasMouse and HasKeyboard then
			Show.Visible = false

			local function GetKeyCodeFromString(KeyString)
				local UpperKey = string.upper(KeyString)

				local SpecialKeys = {
					[";"] = Enum.KeyCode.Semicolon,
					[","] = Enum.KeyCode.Comma,
					["."] = Enum.KeyCode.Period,
					["/"] = Enum.KeyCode.Slash,
					["\\"] = Enum.KeyCode.BackSlash,
					["["] = Enum.KeyCode.LeftBracket,
					["]"] = Enum.KeyCode.RightBracket,
					["'"] = Enum.KeyCode.Quote,
					["`"] = Enum.KeyCode.Backquote,
					["-"] = Enum.KeyCode.Minus,
					["="] = Enum.KeyCode.Equals,
					["SPACE"] = Enum.KeyCode.Space,
					["LMB"] = Enum.KeyCode.ButtonR2,
					["RMB"] = Enum.KeyCode.ButtonL2,
				}

				if SpecialKeys[KeyString] then
					return SpecialKeys[KeyString]
				end

				if SpecialKeys[UpperKey] then
					return SpecialKeys[UpperKey]
				end

				local Success, KeyCode = pcall(function()
					return Enum.KeyCode[UpperKey]
				end)

				if Success and KeyCode then
					return KeyCode
				end

				return nil
			end

			local ToggleKey = GetKeyCodeFromString(Keybind) or Enum.KeyCode.P

			Aero:Notify('Press "' .. Keybind:upper() .. '" to toggle visibility', 3)

			UserInputService.InputBegan:Connect(function(Input)
				if Input.KeyCode == ToggleKey then
					UI_API:Toggle()
				end
			end)
		else
			Show.MouseButton1Click:Connect(function()
				UI_API:Toggle()
			end)
		end

		AeroFrame.Visible = false

		return UI_API
	end
end

local function CreateTab(UIInstance)
	return function(Config)
		Config = Config or {}
		local TabName = Config.Text or "Tab"
		local TabIconInput = Config.Icon

		local TabButton = Instance.new("TextButton", UIInstance.TabsFrame)
		TabButton.Name = TabName .. "Button"
		TabButton.TextWrapped = true
		TabButton.BorderSizePixel = 0
		TabButton.TextSize = 16
		TabButton.TextColor3 = Color3.fromRGB(255, 255, 255)
		TabButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TabButton.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
		TabButton.BackgroundTransparency = 0.93
		TabButton.AutomaticSize = Enum.AutomaticSize.X
		TabButton.Size = UDim2.new(0, 108, 0, 26)
		TabButton.Text = ""

		local TabPadding = Instance.new("UIPadding", TabButton)
		TabPadding.Name = "TabPadding"
		TabPadding.PaddingRight = UDim.new(0, 4)
		TabPadding.PaddingLeft = UDim.new(0, 4)
		TabPadding.PaddingTop = UDim.new(0, 4)
		TabPadding.PaddingBottom = UDim.new(0, 4)

		local TabCorner = Instance.new("UICorner", TabButton)
		TabCorner.Name = "TabCorner"
		TabCorner.CornerRadius = UDim.new(0, 4)

		local SelectionStroke = Instance.new("UIStroke", TabButton)
		SelectionStroke.Name = "SelectionStroke"
		SelectionStroke.Enabled = false
		SelectionStroke.Transparency = 0.5
		SelectionStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		SelectionStroke.Color = Color3.fromRGB(255, 255, 255)

		local TabLayout = Instance.new("UIListLayout", TabButton)
		TabLayout.Name = "TabLayout"
		TabLayout.FillDirection = Enum.FillDirection.Horizontal
		TabLayout.HorizontalFlex = Enum.UIFlexAlignment.Fill
		TabLayout.VerticalFlex = Enum.UIFlexAlignment.Fill
		TabLayout.Padding = UDim.new(0, 4)
		TabLayout.VerticalAlignment = Enum.VerticalAlignment.Center
		TabLayout.SortOrder = Enum.SortOrder.LayoutOrder

		local TabIcon = Instance.new("ImageLabel", TabButton)
		TabIcon.Name = "TabIcon"
		TabIcon.BorderSizePixel = 0
		TabIcon.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TabIcon.Size = UDim2.new(0, 16, 0, 16)
		TabIcon.BackgroundTransparency = 1
		TabIcon.LayoutOrder = 1
		TabIcon.Visible = false

		local TabIconAspect = Instance.new("UIAspectRatioConstraint", TabIcon)
		TabIconAspect.Name = "TabIconAspect"

		local TabText = Instance.new("TextLabel", TabButton)
		TabText.Name = "TabText"
		TabText.TextWrapped = true
		TabText.BorderSizePixel = 0
		TabText.TextScaled = true
		TabText.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TabText.FontFace = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
		TabText.TextColor3 = Color3.fromRGB(255, 255, 255)
		TabText.BackgroundTransparency = 1
		TabText.Size = UDim2.new(0, 0, 0, 0)
		TabText.Text = TabName
		TabText.LayoutOrder = 2
		TabText.AutomaticSize = Enum.AutomaticSize.X

		if TabIconInput then
			local IconImage, Success = GetTabIcon(TabIconInput)
			if Success and IconImage then
				TabIcon.Image = IconImage
				TabIcon.Visible = true
			end
		end

		local TabContent = Instance.new("ScrollingFrame", UIInstance.ContentFrame)
		TabContent.Name = TabName .. "Content"
		TabContent.ScrollingDirection = Enum.ScrollingDirection.Y
		TabContent.BorderSizePixel = 0
		TabContent.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		TabContent.AutomaticCanvasSize = Enum.AutomaticSize.Y
		TabContent.Size = UDim2.new(1, 0, 1, 0)
		TabContent.BackgroundTransparency = 1
		TabContent.ScrollBarThickness = 0
		TabContent.Visible = false

		local TabContentLayout = Instance.new("UIListLayout", TabContent)
		TabContentLayout.Name = "TabContentLayout"
		TabContentLayout.Padding = UDim.new(0, 4)
		TabContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
		TabContentLayout.HorizontalFlex = Enum.UIFlexAlignment.Fill

		UIInstance.Tabs[TabName] = {Button = TabButton, Content = TabContent}
		UIInstance.TabContents[TabName] = TabContent

		TabButton.MouseButton1Click:Connect(function()
			if UIInstance.CurrentTab then
				local CurrentButton = UIInstance.Tabs[UIInstance.CurrentTab].Button
				local CurrentStroke = CurrentButton:FindFirstChild("SelectionStroke")
				if CurrentStroke then
					CurrentStroke.Enabled = false
				end
				UIInstance.TabContents[UIInstance.CurrentTab].Visible = false
			end

			UIInstance.CurrentTab = TabName
			SelectionStroke.Enabled = true
			TabContent.Visible = true
		end)

		if not UIInstance.CurrentTab then
			UIInstance.CurrentTab = TabName
			SelectionStroke.Enabled = true
			TabContent.Visible = true
		end

		return TabContent
	end
end

