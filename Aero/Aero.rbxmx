			local SliderValuePadding = Instance.new("UIPadding", SliderValue)
			SliderValuePadding.Name = "SliderValuePadding"
			SliderValuePadding.PaddingTop = UDim.new(0, 3)
			SliderValuePadding.PaddingRight = UDim.new(0, 3)
