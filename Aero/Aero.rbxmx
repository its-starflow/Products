		local TabsLayout = Instance.new("UIListLayout", TabsFrame)
		TabsLayout.Name = "TabsLayout"
		TabsLayout.Padding = UDim.new(0, 4)
		TabsLayout.SortOrder = Enum.SortOrder.LayoutOrder
		TabsLayout.FillDirection = Enum.FillDirection.Horizontal

		local ContentFrame = Instance.new("ScrollingFrame", AeroFrame)
		ContentFrame.Name = "ContentFrame"
		ContentFrame.ScrollingDirection = Enum.ScrollingDirection.Y
		ContentFrame.BorderSizePixel = 0
		ContentFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		ContentFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
		ContentFrame.Size = UDim2.new(0, 554, 0, 238)
		ContentFrame.Position = UDim2.new(0, 4, 0, 72)
		ContentFrame.ScrollBarThickness = 0
		ContentFrame.BackgroundTransparency = 0.894

		local ContentCorner = Instance.new("UICorner", ContentFrame)
		ContentCorner.Name = "ContentCorner"
