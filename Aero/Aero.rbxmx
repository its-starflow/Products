			ToggleActionPadding.PaddingRight = UDim.new(0, 2)
			ToggleActionPadding.PaddingTop = UDim.new(0, 2)
			ToggleActionPadding.PaddingBottom = UDim.new(0, 2)

			local ToggleActionSC = Instance.new("UISizeConstraint", ToggleAction)
			ToggleActionSC.Name = "ToggleActionSC"
			ToggleActionSC.MaxSize = Vector2.new(66, math.huge)
			ToggleActionSC.MinSize = Vector2.new(50, 0)

			local ToggleActionStroke = Instance.new("UIStroke", ToggleAction)
			ToggleActionStroke.Name = "ToggleActionStroke"
			ToggleActionStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			ToggleActionStroke.Color = Color3.fromRGB(255, 255, 255)

			local ToggleActionCorner = Instance.new("UICorner", ToggleAction)
			ToggleActionCorner.Name = "ToggleActionCorner"
			ToggleActionCorner.CornerRadius = UDim.new(0, 4)

			local ToggleKnob = Instance.new("Frame", ToggleAction)
			ToggleKnob.Name = "ToggleKnob"
			ToggleKnob.BorderSizePixel = 0
			ToggleKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			ToggleKnob.AnchorPoint = Vector2.new(0, 0.5)
			ToggleKnob.Size = UDim2.new(0.5, 0, 1, 0)
			ToggleKnob.Position = UDim2.new(0, 2, 0.5, 0)

			local ToggleKnobCorner = Instance.new("UICorner", ToggleKnob)
			ToggleKnobCorner.Name = "ToggleKnobCorner"
			ToggleKnobCorner.CornerRadius = UDim.new(0, 4)

			local ToggleLayout = Instance.new("UIListLayout", ToggleFrame)
			ToggleLayout.Name = "ToggleLayout"
			ToggleLayout.HorizontalFlex = Enum.UIFlexAlignment.Fill
			ToggleLayout.VerticalFlex = Enum.UIFlexAlignment.Fill
			ToggleLayout.Padding = UDim.new(0, 8)
			ToggleLayout.SortOrder = Enum.SortOrder.LayoutOrder
			ToggleLayout.FillDirection = Enum.FillDirection.Horizontal

			local TogglePadding = Instance.new("UIPadding", ToggleFrame)
			TogglePadding.Name = "TogglePadding"
			TogglePadding.PaddingTop = UDim.new(0, 8)
			TogglePadding.PaddingRight = UDim.new(0, 8)
			TogglePadding.PaddingLeft = UDim.new(0, 4)
			TogglePadding.PaddingBottom = UDim.new(0, 8)

			local ToggleState = Config.Default or false

			local function AnimateToggle()
				local Goal = {}

				if ToggleState then
					Goal.Position = UDim2.new(0.5, 0, 0.5, 0)
				else
					Goal.Position = UDim2.new(0, 0, 0.5, 0)
				end

				local Tween = TweenService:Create(ToggleKnob, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), Goal)
				Tween:Play()
			end

			local function UpdateToggle()
				AnimateToggle()
				if Config.Callback then
					Config.Callback(ToggleState)
				end
			end

			ToggleAction.MouseButton1Click:Connect(function()
				ToggleState = not ToggleState
				UpdateToggle()
			end)

			AnimateToggle()

			return ToggleFrame
		end
	end,

