			local SliderLayout = Instance.new("UIListLayout", SliderFrame)
			SliderLayout.Name = "SliderLayout"
			SliderLayout.HorizontalFlex = Enum.UIFlexAlignment.Fill
			SliderLayout.VerticalFlex = Enum.UIFlexAlignment.Fill
			SliderLayout.Padding = UDim.new(0, 8)
			SliderLayout.SortOrder = Enum.SortOrder.LayoutOrder
			SliderLayout.FillDirection = Enum.FillDirection.Horizontal

			local SliderPadding = Instance.new("UIPadding", SliderFrame)
			SliderPadding.Name = "SliderPadding"
			SliderPadding.PaddingTop = UDim.new(0, 8)
			SliderPadding.PaddingRight = UDim.new(0, 8)
			SliderPadding.PaddingLeft = UDim.new(0, 4)
			SliderPadding.PaddingBottom = UDim.new(0, 8)

			local MinValue = Config.MinValue or 0
			local MaxValue = Config.MaxValue or 100
			local DefaultValue = Config.DefaultValue or MinValue

			local Dragging = false
			local ResizingRight = false
			local EdgeThreshold = 10
			local MinWidth = 0
			local DragOffset = 0

			local function GetMouseX(Input)
				return Input.Position.X - SliderAction.AbsolutePosition.X
			end

			local function Update(Input)
				local SliderWidth = SliderAction.AbsoluteSize.X
				local KnobX = SliderKnob.AbsolutePosition.X - SliderAction.AbsolutePosition.X
				local KnobWidth = SliderKnob.AbsoluteSize.X
				local MouseX = GetMouseX(Input)

				if ResizingRight then
					local NewRight = Clamp(MouseX, KnobX + MinWidth, SliderWidth)
					local NewWidth = NewRight - KnobX
					SliderKnob.Size = UDim2.new(0, NewWidth, SliderKnob.Size.Y.Scale, SliderKnob.Size.Y.Offset)
					local Percent = (NewWidth - 18) / (SliderWidth - 18)
					if Percent <= 0 then Percent = 0 end
					if Percent >= 1 then Percent = 1 end
					SliderValue.Text = ToString(Floor(MinValue + Percent * (MaxValue - MinValue)))
					if Config.Callback then
						Config.Callback(tonumber(SliderValue.Text))
					end
				elseif Dragging then
					local NewX = Clamp(MouseX - DragOffset, 0, SliderWidth - KnobWidth)
					SliderKnob.Position = UDim2.new(0, NewX, SliderKnob.Position.Y.Scale, SliderKnob.Position.Y.Offset)
				end
			end

			SliderKnob.InputBegan:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1
					or Input.UserInputType == Enum.UserInputType.Touch then
					local LocalX = Input.Position.X - SliderKnob.AbsolutePosition.X
					local Width = SliderKnob.AbsoluteSize.X

					if LocalX >= Width - EdgeThreshold then
						ResizingRight = true
						Dragging = false
					else
						Dragging = true
						ResizingRight = false
						DragOffset = LocalX
					end
				end
			end)

			SliderAction.InputBegan:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1
					or Input.UserInputType == Enum.UserInputType.Touch then
					local SliderWidth = SliderAction.AbsoluteSize.X
					local KnobX = SliderKnob.AbsolutePosition.X - SliderAction.AbsolutePosition.X
					local MouseX = GetMouseX(Input)

					ResizingRight = true
					Dragging = false

					local NewRight = Clamp(MouseX, KnobX + MinWidth, SliderWidth)
					local NewWidth = NewRight - KnobX
					SliderKnob.Size = UDim2.new(0, NewWidth, SliderKnob.Size.Y.Scale, SliderKnob.Size.Y.Offset)
				end
			end)

			UserInputService.InputChanged:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseMovement
					or Input.UserInputType == Enum.UserInputType.Touch then
					if Dragging or ResizingRight then
						Update(Input)
					end
				end
			end)

			UserInputService.InputEnded:Connect(function(Input)
				if Input.UserInputType == Enum.UserInputType.MouseButton1
					or Input.UserInputType == Enum.UserInputType.Touch then
					Dragging = false
					ResizingRight = false
				end
			end)

			local InitialWidth = 18 + ((DefaultValue - MinValue) / (MaxValue - MinValue)) * (80 - 18)
			SliderKnob.Size = UDim2.new(0, InitialWidth, 0, 18)
			SliderValue.Text = ToString(DefaultValue)

			return SliderFrame
		end
	end,

