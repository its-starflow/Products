local function CreateElement(Type, Parent)
	local Handler = ElementTypes[Type]
	if not Handler then
		error("Unknown element type: " .. ToString(Type))
	end
	return Handler(Parent)
end

function Aero:Notify(Text, DurationValue)
	return Notify(Text, DurationValue)
end

function Aero:New(Type, Parent)
	if Type == "UI" then
		return CreateUI()
	elseif Type == "Tab" then
		return CreateTab(Parent)
	elseif ElementTypes[Type] then
		return CreateElement(Type, Parent)
	else
		error("Unknown type: " .. ToString(Type))
	end
end

