local NotificationOrderCounter = 1

local function Notify(Text, DurationValue)
	local DurationNum = tonumber(DurationValue) or 3
	if DurationNum > 10 then
		DurationNum = 10
	elseif DurationNum < 1 then
		DurationNum = 1
	end

	local ClonedWrapper = NotificationWrapper:Clone()
	ClonedWrapper.Parent = NotificationContainer
	ClonedWrapper.Visible = true

	local ClonedNotification = ClonedWrapper.Notification
	local ClonedDescription = ClonedNotification.Description
	local ClonedDuration = ClonedNotification.Topbar.Duration

	ClonedDescription.Text = Text or "Notification"
	ClonedDuration.Text = ToString(Floor(DurationNum))

	local CurrentOrder = NotificationOrderCounter
	NotificationOrderCounter = NotificationOrderCounter + 1
	ClonedWrapper.LayoutOrder = CurrentOrder

	local HomePos = UDim2.new(0, 0, 0, 0)
	local TargetPos = UDim2.new(2, 0, 0, 0)

	ClonedNotification.Position = TargetPos
	ClonedNotification.Visible = true

	local OvershootPos = UDim2.new(-0.1, 0, 0, 0)

	BounceTween(ClonedNotification, {
		Position = OvershootPos
	}, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

	BounceTween(ClonedNotification, {
		Position = HomePos
	}, 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	Defer(function()
		Wait()

		local ViewportY = Camera.ViewportSize.Y
		local AbsPosY = ClonedWrapper.AbsolutePosition.Y
		local AbsSizeY = ClonedWrapper.AbsoluteSize.Y

		local Bottom = AbsPosY + AbsSizeY

		local Delta = 0

		if Bottom > ViewportY then
			Delta = ViewportY - Bottom
		elseif AbsPosY < 0 then
			Delta = -AbsPosY
		end

		if Delta ~= 0 then
			ClonedWrapper.Position = ClonedWrapper.Position + UDim2.new(0, 0, 0, Delta)
		end
	end)

	local StartTime = Tick()
	local CountdownConnection
	CountdownConnection = RunService.Heartbeat:Connect(function()
		if not ClonedNotification.Parent then
			CountdownConnection:Disconnect()
			return
		end

		local Elapsed = Tick() - StartTime
		local Remaining = Max(0, DurationNum - Elapsed)
		ClonedDuration.Text = ToString(Ceil(Remaining))

		if Remaining <= 0 then
			CountdownConnection:Disconnect()
		end
	end)

	Wait(DurationNum)

	if CountdownConnection then
		CountdownConnection:Disconnect()
	end

	local SlideOutTween = TweenService:Create(
		ClonedNotification,
		TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = UDim2.new(2, 0, 0, 0) }
	)

	SlideOutTween:Play()
	SlideOutTween.Completed:Wait()

	ClonedWrapper:Destroy()

	local RemainingWrappers = {}
	local NewOrder = 1

	for _, Wrapper in IPairs(NotificationContainer:GetChildren()) do
		if Wrapper:IsA("Frame") and Wrapper.Name == "NotificationWrapper" and Wrapper.Visible then
			TableInsert(RemainingWrappers, Wrapper)
		end
	end

	TableSort(RemainingWrappers, function(A, B)
		return A.LayoutOrder < B.LayoutOrder
	end)

	for _, Wrapper in IPairs(RemainingWrappers) do
		Wrapper.LayoutOrder = NewOrder
		NewOrder = NewOrder + 1
	end

	NotificationOrderCounter = NewOrder
end

local UI_API_MT = {
	Destroy = function(Self)
		Self.ScreenGui:Destroy()
		Aero.IsLoaded = false
	end,

	Show = function(Self)
		if Self.Aero.Visible then return end
		local Directions = {"Top", "Bottom", "Left", "Right"}
		local RandomDirection = Directions[Random(1, 4)]
		SlideIn(Self.Aero, Self.HomePosition, RandomDirection)
	end,

	Hide = function(Self)
		if not Self.Aero.Visible then return end
		local Directions = {"Top", "Bottom", "Left", "Right"}
		local RandomDirection = Directions[Random(1, 4)]
		SlideOut(Self.Aero, Self.HomePosition, RandomDirection)
	end,

	Toggle = function(Self)
		if Self.Aero.Visible then
			Self:Hide()
		else
			Self:Show()
		end
	end
}
UI_API_MT.__index = UI_API_MT

local function CreateUI()
	return function(Config)
		Config = Config or {}
		local Title = Config.Title or "Aero Hub"
		local Alignment = Config.Alignment or "TopRight"
		local Keybind = Config.Keybind or "P"

		local ScreenGui = Instance.new("ScreenGui", PlayerGui)
		local SanitizedTitle = string.gsub(Title, "%s+", "")
		ScreenGui.Name = "Aero." .. SanitizedTitle
		ScreenGui.DisplayOrder = 2147483646
		ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

		local Show = Instance.new("ImageButton", ScreenGui)
		Show.Name = "Show"
		Show.BorderSizePixel = 0
		Show.BackgroundColor3 = Color3.fromRGB(10, 10, 10)

		if Alignment == "TopLeft" then
			Show.AnchorPoint = Vector2.new(0, 0)
			Show.Position = UDim2.new(0, 5, 0, 2)
		elseif Alignment == "TopRight" then
			Show.AnchorPoint = Vector2.new(1, 0)
			Show.Position = UDim2.new(1, -5, 0, 2)
		elseif Alignment == "BottomLeft" then
			Show.AnchorPoint = Vector2.new(0, 1)
			Show.Position = UDim2.new(0, 5, 1, -5)
		elseif Alignment == "BottomRight" then
			Show.AnchorPoint = Vector2.new(1, 1)
			Show.Position = UDim2.new(1, -5, 1, -5)
		else
			Show.AnchorPoint = Vector2.new(1, 0)
			Show.Position = UDim2.new(1, -5, 0, 2)
