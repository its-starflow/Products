local Assets = {
	["Aero/Images/Icon.png"] = {
		URL = "https://raw.githubusercontent.com/its-starflow/Aero/Core/Images/Icon.png",
		ID = "rbxassetid://98493725286936"
	},
	["Aero/Images/Background.png"] = {
		URL = "https://raw.githubusercontent.com/its-starflow/Aero/Core/Images/Background.png",
		ID = "rbxassetid://125628966001017"
	},
	["Aero/Images/Click.png"] = {
		URL = "https://raw.githubusercontent.com/its-starflow/Aero/Core/Images/Click.png",
		ID = "rbxassetid://12804017021"
	}
}

local function GetAsset(Path)
	local Asset = Assets[Path]
	if not Asset then
		return nil
	end

	if RunService:IsStudio() or (not getcustomasset and not getsynasset) then
		return Asset.ID
	end

	if not isfolder("Aero") then
		makefolder("Aero")
	end
	if not isfolder("Aero/Images") then
		makefolder("Aero/Images")
	end

	if not isfile(Path) then
		local Success, Data = pcall(function()
			return game:HttpGet(Asset.URL)
		end)
		if Success and Data then
			writefile(Path, Data)
		else
			return Asset.ID
		end
	end

	return (getcustomasset or getsynasset)(Path)
end

local function GetTabIcon(IconInput)
	if not IconInput or IconInput == "" then
		return nil, false
	end

	local IconLower = Lower(IconInput)

	if Find(IconLower, "^rbxassetid://") then
		return IconInput, true
	end

	if Find(IconLower, "^https?://") then
		if not getcustomasset and not getsynasset then
			return nil, false
		end

		if not isfolder("Aero") then
			makefolder("Aero")
		end
		if not isfolder("Aero/Images") then
			makefolder("Aero/Images")
		end
		if not isfolder("Aero/Images/Cache") then
			makefolder("Aero/Images/Cache")
		end

		local Hash = HttpService:GenerateGUID(false)
		local FileName = "Aero/Images/Cache/" .. Hash .. ".png"

		if not isfile(FileName) then
			local Success, Data = pcall(function()
				return game:HttpGet(IconInput)
			end)
			if Success and Data then
				writefile(FileName, Data)
			else
				return nil, false
			end
		end

		return (getcustomasset or getsynasset)(FileName), true
	end

	if Find(IconLower, "^%d+$") then
		return "rbxassetid://" .. IconInput, true
	end

	return nil, false
end

local AnimationManager = {
	IsAnimating = false
}

local function BounceTween(Object, Goal, Time, Style, Direction)
	local Tween = TweenService:Create(Object, TweenInfo.new(Time, Style, Direction), Goal)
	Tween:Play()
	Tween.Completed:Wait()
end

local function GetStartPosition(Dir, HomePos, Target)
	local ParentSize = Target.Parent.AbsoluteSize
	local TargetSize = Target.AbsoluteSize

	if Dir == "Top" then
		return UDim2.fromOffset(HomePos.X.Offset, -TargetSize.Y)
	elseif Dir == "Bottom" then
		return UDim2.fromOffset(HomePos.X.Offset, ParentSize.Y)
	elseif Dir == "Left" then
		return UDim2.fromOffset(-TargetSize.X, HomePos.Y.Offset)
	elseif Dir == "Right" then
		return UDim2.fromOffset(ParentSize.X, HomePos.Y.Offset)
	end

	return UDim2.fromOffset(HomePos.X.Offset, ParentSize.Y)
end

local function GetOvershootPosition(Dir, HomePos)
	if Dir == "Top" then
		return UDim2.fromOffset(HomePos.X.Offset, HomePos.Y.Offset + 30)
	elseif Dir == "Bottom" then
		return UDim2.fromOffset(HomePos.X.Offset, HomePos.Y.Offset - 30)
	elseif Dir == "Left" then
		return UDim2.fromOffset(HomePos.X.Offset + 30, HomePos.Y.Offset)
	elseif Dir == "Right" then
		return UDim2.fromOffset(HomePos.X.Offset - 30, HomePos.Y.Offset)
	end

	return HomePos
end

local function GetRotation(Dir)
	if Dir == "Left" then
		return -8, 2
	elseif Dir == "Right" then
		return 8, -2
	elseif Dir == "Top" then
		return -6, 1
	elseif Dir == "Bottom" then
		return 6, -1
	end

	return -8, 2
end

local function SlideIn(Target, HomePos, Direction)
	if AnimationManager.IsAnimating then return end
	AnimationManager.IsAnimating = true

	Target.Visible = true

	local StartPos = GetStartPosition(Direction, HomePos, Target)
	local OvershootPos = GetOvershootPosition(Direction, HomePos)
	local StartRot, MidRot = GetRotation(Direction)

	Target.Position = StartPos
	Target.Rotation = StartRot

	BounceTween(Target, {
		Position = OvershootPos,
		Rotation = MidRot
	}, 0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

	BounceTween(Target, {
		Position = HomePos,
		Rotation = 0
	}, 0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

	AnimationManager.IsAnimating = false
end

local function SlideOut(Target, HomePos, Direction)
	if AnimationManager.IsAnimating then return end
	AnimationManager.IsAnimating = true

	local TargetPos = GetStartPosition(Direction, HomePos, Target)
	local MoveTween = TweenService:Create(Target, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Position = TargetPos,
		Rotation = 10
	})

	MoveTween:Play()
	MoveTween.Completed:Wait()
	Target.Visible = false
	AnimationManager.IsAnimating = false
end

local function SetDraggable(Instance, OnPositionChanged)
	local Dragging = false
	local DragStart
	local StartPos

	Instance.InputBegan:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 
			or Input.UserInputType == Enum.UserInputType.Touch then
			Dragging = true
			DragStart = Input.Position
			StartPos = Instance.AbsolutePosition

			Input.Changed:Connect(function()
				if Input.UserInputState == Enum.UserInputState.End then
					Dragging = false
					if OnPositionChanged then
						OnPositionChanged(Instance.Position)
					end
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(Input)
		if not Dragging then return end
		if Input.UserInputType == Enum.UserInputType.MouseMovement
			or Input.UserInputType == Enum.UserInputType.Touch then
			local Delta = Input.Position - DragStart
			local Parent = Instance.Parent
			local ParentSize = Parent.AbsoluteSize
			local ObjSize = Instance.AbsoluteSize
			local NewX = Clamp(StartPos.X + Delta.X, 0, ParentSize.X - ObjSize.X)
			local NewY = Clamp(StartPos.Y + Delta.Y, 0, ParentSize.Y - ObjSize.Y)
			Instance.Position = UDim2.fromOffset(NewX, NewY)
			if OnPositionChanged then
				OnPositionChanged(Instance.Position)
			end
		end
	end)
end

