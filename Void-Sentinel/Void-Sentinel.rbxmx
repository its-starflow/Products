					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local Punish = {}

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Notify = ReplicatedStorage:WaitForChild("VS-Remotes"):WaitForChild("NotifyEvent")

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

local Messages = {
	"potato firewall didnt like that",
	"u pressed the wrong thing bro",
	"server hamster lost trust",
	"pixels reported u",
	"anti noob system said no",
	"spaghetti code fought back",
	"skill dlc missing",
	"wizard removed ur perms",
	"button got offended",
	"secret ban ending unlocked",
	"anti cheat dragon said no",
	"that was dumb",
	"lua spirits angry",
	"ducks are disappointed",
	"firewall facepalmed",
	"clown protocol active",
	"anti cheese denied u",
	"that did nothing btw",
	"ninjas got u",
	"common sense missing",
	"server said nah",
	"lego incident",
	"too much confidence",
	"raccoon stole access",
	"server laughed at u",
	"shadow realm time",
	"spaghetti dimension said no",
	"not the chosen one",
	"rubber ducks stopped u",
	"spirits shaking heads",
	"wifi ghosts detected",
	"404 brain not found",
	"keyboard cried for help",
	"ur luck expired",
	"bad idea generator active",
	"cheese pass revoked",
	"banana security triggered",
	"server duck attacked",
	"that aint gonna work",
	"gravity reported u",
	"packet inspector laughing",
	"minecraft villager disagreed",
	"admin raccoon watching",
	"toaster security online",
	"mission failed horribly",
	"void goblins noticed u",
	"cpu overheating from stupidity",
	"keyboard warrior defeated",
	"air molecules suspicious",
	"wormhole denied request",
	"frog army intervened",
	"security potato evolved",
	"access card exploded",
	"magic smoke escaped",
	"server cat hissed",
	"error 123 skill issue",
	"lua wizard disappointed",
	"anti exploit goblin angry",
	"hamster fell off wheel",
	"banana peel detected",
	"security turtle too fast",
	"ur permissions evaporated",
	"chair anti cheat enabled",
	"code monkeys upset",
	"invisible wall wins again",
	"wifi raccoon stole packets",
	"kernel panic emotionally",
	"ur aura got detected",
	"developer sigh detected",
	"system integrity laughing",
	"void seal activated",
	"spoon protocol denied",
	"mouse disconnected spiritually",
	"npc council voted no",
	"bad vibes detected",
	"rubber chicken defense active",
	"anti fun barrier enabled",
	"keyboard exploded internally",
	"quantum duck intervened",
	"ur exploit tripped itself",
	"packet goblins confused",
	"server spine broke",
	"admin fish watching closely",
	"nah bro caught in 4k",
	"security banana armed",
	"too goofy detected",
	"anti clown shield active",
	"rat detector online",
	"ur script folded instantly",
	"lua itself rejected u",
	"ur exploit needs therapy",
	"ghosts unplugged ur access",
	"anti weird system triggered",
	"meme firewall blocked u",
	"dragon firewall awakened",
	"code spirits screaming",
	"anti monkey protocol active",
	"reality patch successful",
	"ur bypass bypassed itself",
	"clouds reported suspicious activity",
	"server lost patience",
	"that exploit from temu?",
	"void gods disapproved",
	"admin hamster spinning violently",
	"critical bruh moment",
	"anti tomfoolery activated",
	"security raccoon eating wires",
	"system.exe stopped believing in u"
}

local Prefix = "[Void-Sentinel]: "

local DetectionData = {}
local DetectionCooldowns = {}

local DETECTION_COOLDOWN = 5

local function GetMax()
	return (Settings.Punishments and Settings.Punishments.MaxDetections) or 3
end

function Punish:Reset(Player)
	DetectionData[Player] = nil
	DetectionCooldowns[Player] = nil
end

function Punish:Warn(Player, DetectionName, Count, Max)
	if not Player then
		return
	end

	local TextMessage = string.format(
		"Detected by %s (%d/%d)",
		tostring(DetectionName),
		Count or 1,
		Max or GetMax()
	)

	Notify:FireClient(Player, Prefix, TextMessage)
end

function Punish:Kick(Player, DetectionName, CustomReason)
	if not Player then
		return
	end

	local Reason = CustomReason or Messages[math.random(1, #Messages)]
	local Message = Prefix .. Reason .. "\nDetection: " .. tostring(DetectionName)

	Player:Kick(Message)
end

function Punish:AddDetection(Player, DetectionName)
	if not Player then
		return false
	end

	local now = tick()

	DetectionCooldowns[Player] = DetectionCooldowns[Player] or 0

	if now - DetectionCooldowns[Player] < DETECTION_COOLDOWN then
		return false
	end

	DetectionCooldowns[Player] = now

	local MaxDetections = GetMax()

	DetectionData[Player] = DetectionData[Player] or {}
	local Data = DetectionData[Player]

	Data[DetectionName] = Data[DetectionName] or 0

	if Data[DetectionName] >= MaxDetections then
		return true
	end

	Data[DetectionName] += 1

	local Count = Data[DetectionName]

	self:Warn(Player, DetectionName, Count, MaxDetections)

	if Count >= MaxDetections then
		task.delay(2, function()
			if Player and Player.Parent then
				self:Kick(Player, DetectionName)
			end
		end)

		return true
	end

	return false
end

Players.PlayerRemoving:Connect(function(Player)
	Punish:Reset(Player)
end)

return Punish]]></ProtectedString>
