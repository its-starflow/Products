		<Item class="ModuleScript" referent="RBX60F1BB7CEE864487ADF29E92597DE910">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[local Settings = {
	Enabled = true,

	Detection = {
		AntiBackdoor = true, -- Detects suspicious scripts trying to control the game
		AntiRemoteSpam = true, -- Detects RemoteEvent spam

		AntiFly = true, -- Prevents players from flying around
		AntiNoclip = true, -- Stops players from walking through walls
		AntiSpeed = true, -- Detects abnormal movement speed
		AntiTeleport = true, -- Detects instant position changes
		AntiReach = true, -- Prevents players from hitting from unrealistic distances

		AntiGodMode = true, -- Prevents players from becoming invincible
	},

	Punishments = {
		Kick = true,
		Warn = true,

		-- Amount of detections before punishment is applied.
		MaxDetections = 3,

		-- Time before detection count resets.
		DetectionCooldown = 5
	},

	Thresholds = {
		Movement = {
			-- Extra leniency for lag/ping differences.
			PositionTolerance = 8,

			-- Delay before movement checks start after spawning.
			GraceTime = 3,

			-- Max allowed horizontal movement before flagged as teleporting.
			MaxHorizontalTeleportDistance = 80,

			-- Max allowed vertical movement before flagged.
			MaxVerticalTeleportDistance = 120,

			-- General teleport distance limit used by movement checks.
			TeleportDistance = 100
		},

		Remote = {
			-- Max RemoteEvent requests allowed in the time window.
			MaxRequests = 40,

			-- How long requests are tracked for.
			TimeWindow = 1
		},

		Character = {
			-- Allowed walkspeeds used in your game.
			WhitelistedWalkSpeeds = {
				16,
				32
			},

			-- Allowed jump powers used in your game.
			WhitelistedJumpPowers = {
				50,
				75
			}
		},

		Rules = {
			-- Ignores the first teleport after spawning.
			IgnoreFirstTeleport = true
		},

		MovementWhitelistParts = {
			-- Parts that are allowed to launch or move players.
			-- Remove example before publishing.
			game.Workspace.Map.Other.Trampoline.JumpHitbox
		}
	},

	Debug = {
		-- Prints anti-cheat logs/errors in the output.
		PrintErrors = true
	}
}

return Settings]]></ProtectedString>
