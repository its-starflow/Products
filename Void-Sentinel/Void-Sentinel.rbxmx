				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX9F421019E81644DD98D8D3CF69199C42">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiTeleport = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiTeleport then
	return AntiTeleport
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local PlayerData = {}

local MovementSettings = Settings.Thresholds.Movement
local RuleSettings = Settings.Thresholds.Rules

local function IsCharacterValid(Character)
	if not Character then
		return false
	end

	local Humanoid = Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Character:FindFirstChild("HumanoidRootPart")

	return Humanoid and RootPart
end

local function IsInsideWhitelistedPart(RootPart)
	for _, Part in ipairs(Settings.Thresholds.MovementWhitelistParts) do
		if Part and Part:IsA("BasePart") then
			local Relative = Part.CFrame:PointToObjectSpace(RootPart.Position)
			local Half = Part.Size / 2

			if math.abs(Relative.X) <= Half.X
				and math.abs(Relative.Y) <= Half.Y
				and math.abs(Relative.Z) <= Half.Z then
				return true
			end
		end
	end

	return false
end

local function ResetPlayer(Player)
	PlayerData[Player] = nil
end

local function SetupPlayer(Player)
	Player.CharacterAdded:Connect(function(Character)
		local Humanoid = Character:WaitForChild("Humanoid")
		local RootPart = Character:WaitForChild("HumanoidRootPart")

		PlayerData[Player] = {
			LastPosition = RootPart.Position,
			LastTime = tick(),
			TeleportGrace = tick() + 1,
			BoostTime = 0,
			BoostPosition = nil,
			BoostWalkSpeed = 0,
			FirstTeleportIgnored = false
		}

		Humanoid.Died:Connect(function()
			ResetPlayer(Player)
		end)
	end)
end

Players.PlayerAdded:Connect(SetupPlayer)

for _, Player in ipairs(Players:GetPlayers()) do
	task.spawn(SetupPlayer, Player)
end

Players.PlayerRemoving:Connect(ResetPlayer)

RunService.Heartbeat:Connect(function(dt)
	for _, Player in ipairs(Players:GetPlayers()) do
		local Data = PlayerData[Player]
		if not Data then continue end

		local Character = Player.Character
		if not IsCharacterValid(Character) then continue end

		local Humanoid = Character:FindFirstChildOfClass("Humanoid")
		local RootPart = Character:FindFirstChild("HumanoidRootPart")

		if not Humanoid or Humanoid.Health <= 0 or Humanoid.SeatPart then continue end

		local now = tick()

		if IsInsideWhitelistedPart(RootPart) then
			Data.BoostTime = now
			Data.BoostPosition = RootPart.Position
			Data.BoostWalkSpeed = Humanoid.WalkSpeed
		end

		local current = RootPart.Position
		local delta = current - Data.LastPosition

		local horizontalDistance = Vector3.new(delta.X, 0, delta.Z).Magnitude
		local verticalDistance = math.abs(delta.Y)

		local allowedMovement = (Humanoid.WalkSpeed * dt) + MovementSettings.PositionTolerance
		local inGrace = now <= Data.TeleportGrace
		local detected = false

		if Data.BoostPosition and (now - Data.BoostTime) <= MovementSettings.GraceTime then
			local horizontalBoostDelta = Vector3.new(current.X, 0, current.Z) - Vector3.new(Data.BoostPosition.X, 0, Data.BoostPosition.Z)
			local boostAllowed = (Data.BoostWalkSpeed * (now - Data.BoostTime)) + MovementSettings.PositionTolerance

			if horizontalBoostDelta.Magnitude > boostAllowed then
				detected = true
			end
		else
			if not inGrace then
				if horizontalDistance > math.max(allowedMovement, MovementSettings.MaxHorizontalTeleportDistance) then
					detected = true
				end

				if verticalDistance > MovementSettings.MaxVerticalTeleportDistance then
					if RootPart.AssemblyLinearVelocity.Y > -5 then
						detected = true
					end
				end
			end
		end

		if detected then
			if RuleSettings.IgnoreFirstTeleport and not Data.FirstTeleportIgnored then
				Data.FirstTeleportIgnored = true
				Data.LastPosition = current
				Data.LastTime = now
				continue
			end

			Character:PivotTo(CFrame.new(Data.LastPosition))

			if Punish:AddDetection(Player, "AntiTeleport") then
				return
			end
		else
			Data.LastPosition = current
			Data.LastTime = now
		end
	end
end)

return AntiTeleport]]></ProtectedString>
