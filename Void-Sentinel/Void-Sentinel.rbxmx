					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiReach = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))
if not Settings.Enabled or not Settings.Detection.AntiReach then
	return AntiReach
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local MAX_REACH = 7

function AntiReach.Validate(Attacker, Victim)
	local AttackerRoot = Attacker:FindFirstChild("HumanoidRootPart")
	local VictimRoot = Victim:FindFirstChild("HumanoidRootPart")

	if not AttackerRoot or not VictimRoot then return false end

	local Distance = (AttackerRoot.Position - VictimRoot.Position).Magnitude

	if Distance > MAX_REACH then
		if Punish:AddDetection(Attacker, "AntiReach") then
			return false
		end
	end

	return true
end

return AntiReach]]></ProtectedString>
