					<ProtectedString name="Source"><![CDATA[local AntiRemoteSpam = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))
local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))
local Players = game:GetService("Players")

local RemoteLimits = {}
local MAX_REQUESTS = Settings.Thresholds.Remote.MaxRequests
local TIME_WINDOW = Settings.Thresholds.Remote.TimeWindow

local function ResetPlayer(Player)
	RemoteLimits[Player] = nil
end

Players.PlayerRemoving:Connect(ResetPlayer)

function AntiRemoteSpam.Hook(RemoteEvent)
	local OriginalFire = RemoteEvent.OnServerEvent

	RemoteEvent.OnServerEvent = function(Player, ...)
		local now = tick()
		local data = RemoteLimits[Player] or { Requests = 0, LastReset = now }

		if now - data.LastReset > TIME_WINDOW then
			data.Requests = 1
			data.LastReset = now
		else
			data.Requests += 1
			if data.Requests > MAX_REQUESTS then
				if Punish:AddDetection(Player, "AntiRemoteSpam") then
					return
				end
			end
		end

		RemoteLimits[Player] = data
		OriginalFire(Player, ...)
	end
end

return AntiRemoteSpam]]></ProtectedString>
