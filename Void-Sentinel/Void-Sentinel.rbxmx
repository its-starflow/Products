					<ProtectedString name="Source"><![CDATA[local AntiGodMode = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiGodMode then
	return AntiGodMode
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local Players = game:GetService("Players")

local GodModeSettings = {
	AllowedHealMargin = 1,
	MinDeathHealth = 0.1,
}

local PlayerData = {}

local function ResetPlayer(Player)
	PlayerData[Player] = nil
end

local function SetupPlayer(Player)
	Player.CharacterAdded:Connect(function(Character)
		local Humanoid = Character:WaitForChild("Humanoid", 5) :: Humanoid
		if not Humanoid then return end

		task.wait(1)

		if not Character or not Character.Parent then return end

		PlayerData[Player] = {
			LastHealth = Humanoid.Health
		}

		local HealthChangedConn
		HealthChangedConn = Humanoid.HealthChanged:Connect(function(CurrentHealth)
			if not Character or not Character.Parent then
				if HealthChangedConn then HealthChangedConn:Disconnect() end
				return
			end

			local Data = PlayerData[Player]
			if not Data then return end

			local LastHealth = Data.LastHealth

			if CurrentHealth > LastHealth + GodModeSettings.AllowedHealMargin then
				local IsSeated = Humanoid.SeatPart ~= nil

				if CurrentHealth == Humanoid.MaxHealth and LastHealth <= GodModeSettings.MinDeathHealth and not IsSeated then
					if Punish:AddDetection(Player, "AntiGodMode") then
						if HealthChangedConn then HealthChangedConn:Disconnect() end
						return
					end
				end
			end

			Data.LastHealth = CurrentHealth
		end)

		local DestroyingConn
		DestroyingConn = Character.Destroying:Connect(function()
			if HealthChangedConn then HealthChangedConn:Disconnect() end
			DestroyingConn:Disconnect()
		end)
	end)
end

Players.PlayerAdded:Connect(SetupPlayer)

for _, Player in ipairs(Players:GetPlayers()) do
	task.spawn(SetupPlayer, Player)
end

Players.PlayerRemoving:Connect(ResetPlayer)

return AntiGodMode]]></ProtectedString>
