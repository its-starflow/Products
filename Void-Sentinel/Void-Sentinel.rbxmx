					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiBackdoor = {}

math.randomseed(tick() + os.clock())

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiBackdoor then
	return AntiBackdoor
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local function GetService(ServiceName)
	local Success, Service = pcall(game.GetService, game, ServiceName)
	while not Success or not Service do
		task.wait()
		Success, Service = pcall(game.GetService, game, ServiceName)
	end
	return Service
end

local ReplicatedStorage = GetService("ReplicatedStorage")
local Workspace = GetService("Workspace")
local HttpService = GetService("HttpService")

local Characters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()-_=+;:',.<>/?\\|`~"
local SafeCharacters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"

local TrapRemotes = {}
local KickedPlayers = {}

local function Randomize(Length, Safe)
	local CharacterSet = Safe and SafeCharacters or Characters
	local String = ""

	for i = 1, Length do
		local Index = math.random(1, #CharacterSet)
		String ..= CharacterSet:sub(Index, Index)
	end

	return String
end

local function GetRandomContainer(Parent)
	local Valid = {}

	for _, Object in ipairs(Parent:GetDescendants()) do
		if Object:IsA("Folder") or Object:IsA("Model") or Object:IsA("Configuration") then
			table.insert(Valid, Object)
		end
	end

	if #Valid > 0 then
		return Valid[math.random(1, #Valid)]
	end

	return Parent
end

local function ObfuscateRemote(Remote)
	Remote.Name = Randomize(math.random(32, 64))
	Remote:SetAttribute(Randomize(8, true), HttpService:GenerateGUID(false))
	Remote:SetAttribute(Randomize(10, true), Randomize(20))
	Remote:SetAttribute(Randomize(12, true), math.random(100000, 999999))
	Remote:SetAttribute(Randomize(14, true), tick())
	Remote.Archivable = false
end

local function KillPlayer(Player, Reason)
	if not Player or KickedPlayers[Player] then
		return
	end

	KickedPlayers[Player] = true

	Punish:Kick(Player, "AntiBackdoor", Reason)
end

local function CreateTrapRemote(Parent)
	local Container = GetRandomContainer(Parent)
	local Remote = Instance.new("RemoteEvent")

	ObfuscateRemote(Remote)
	Remote.Parent = Container

	Remote.OnServerEvent:Connect(function(Player)
		KillPlayer(Player, "Backdoor remote triggered")
	end)

	return Remote
end

local function EnsureTrap(LocationName, Parent)
	local Existing = TrapRemotes[LocationName]
	if Existing and Existing.Parent then
		return
	end

	local Success, Remote = pcall(function()
		return CreateTrapRemote(Parent)
	end)

	if Success and Remote then
		TrapRemotes[LocationName] = Remote
	end
end

EnsureTrap("Workspace", Workspace)
EnsureTrap("ReplicatedStorage", ReplicatedStorage)

task.spawn(function()
	while true do
		task.wait(math.random(30, 90))
		EnsureTrap("Workspace", Workspace)
		EnsureTrap("ReplicatedStorage", ReplicatedStorage)
	end
end)

game:GetService("Players").PlayerRemoving:Connect(function(Player)
	KickedPlayers[Player] = nil
end)

return AntiBackdoor]]></ProtectedString>
					<string name="ScriptGuid">{1D3359DA-500A-4894-BA0D-4A4F572DCDD5}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">AntiBackdoor</string>
					<int64 name="SourceAssetId">-1</int64>
