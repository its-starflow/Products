				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBXB2B7885CE4AE47AB96AD88BF22DF1E8E">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiNoclip = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiNoclip then
	return AntiNoclip
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local PlayerData = {}

local MIN_DISTANCE_CHECK = 1
local MAX_CHECK_DISTANCE = 35 -- Slightly increased to account for fast vehicles

local RaycastParams = RaycastParams.new()
RaycastParams.FilterType = Enum.RaycastFilterType.Exclude

local function IsCharacterValid(Character)
	if not Character then
		return false
	end

	local Humanoid = Character:FindFirstChildOfClass("Humanoid")
	local RootPart = Character:FindFirstChild("HumanoidRootPart")

	return Humanoid and RootPart
end

local function ResetPlayer(Player)
	PlayerData[Player] = nil
end

local function SetupCharacter(Player, Character)
	local RootPart = Character:WaitForChild("HumanoidRootPart")

	PlayerData[Player] = {
		LastPosition = RootPart.Position,
		LastSafePosition = RootPart.Position,
	}
end

local function SetupPlayer(Player)
	Player.CharacterAdded:Connect(function(Character)
		SetupCharacter(Player, Character)
	end)

	if Player.Character then
		task.spawn(SetupCharacter, Player, Player.Character)
	end
end

Players.PlayerAdded:Connect(SetupPlayer)

for _, Player in ipairs(Players:GetPlayers()) do
	task.spawn(SetupPlayer, Player)
end

Players.PlayerRemoving:Connect(ResetPlayer)

RunService.Heartbeat:Connect(function()
	for _, Player in ipairs(Players:GetPlayers()) do
		local Data = PlayerData[Player]
		local Character = Player.Character

		if not Data or not IsCharacterValid(Character) then
			continue
		end

		local Humanoid = Character:FindFirstChildOfClass("Humanoid")
		local RootPart = Character:FindFirstChild("HumanoidRootPart")

		if not Humanoid or Humanoid.Health <= 0 then
			continue
		end

		local CurrentSeat = Humanoid.SeatPart
		local TargetPart = RootPart
		local IgnoreInstances = { Character }

		if CurrentSeat and CurrentSeat:IsA("BasePart") then
			TargetPart = CurrentSeat

			local VehicleModel = CurrentSeat:FindFirstAncestorOfClass("Model")
			if VehicleModel then
				table.insert(IgnoreInstances, VehicleModel)
			else
				table.insert(IgnoreInstances, CurrentSeat)
			end
		end

		local CurrentPosition = TargetPart.Position
		local LastPosition = Data.LastPosition

		local Direction = CurrentPosition - LastPosition
		local Distance = Direction.Magnitude

		if Distance < MIN_DISTANCE_CHECK then
			continue
		end

		if Distance > MAX_CHECK_DISTANCE then
			Data.LastPosition = CurrentPosition
			continue
		end

		RaycastParams.FilterDescendantsInstances = IgnoreInstances

		local Result = Workspace:Raycast(LastPosition, Direction, RaycastParams)

		if Result and Result.Instance and Result.Instance.CanCollide then
			if CurrentSeat then
				local VehicleModel = CurrentSeat:FindFirstAncestorOfClass("Model")
				local AssemblyPart = CurrentSeat.AssemblyRootPart or CurrentSeat

				AssemblyPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
				AssemblyPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

				if VehicleModel and VehicleModel:PrimaryPart() then
					VehicleModel:PivotTo(CFrame.new(Data.LastSafePosition))
				else
					CurrentSeat.CFrame = CFrame.new(Data.LastSafePosition)
				end
			else
				RootPart.CFrame = CFrame.new(Data.LastSafePosition)
			end

			if Punish:AddDetection(Player, "AntiNoclip") then
				return
			end
		else
			Data.LastSafePosition = CurrentPosition
		end

		Data.LastPosition = CurrentPosition
	end
end)

return AntiNoclip]]></ProtectedString>
					<string name="ScriptGuid">{E3236BE0-523B-4F58-AF6D-A7095DDBEE4D}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">AntiNoclip</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX36A23353BF174FC989C02180333C0BA9">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiFly = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiFly then
	return AntiFly
end

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local FlySettings = {
	Intervals = 10,
	MaxDistanceFromGround = Vector3.new(0, -18, 0),
	MaxAirTime = 2,
	MinimumFlySpeed = 35,
	AddPlatformStandStrike = true
}

local PlayerData = {}
local CurrentInterval = 0

local MovementSettings = Settings.Thresholds.Movement

local function ResetPlayer(Player)
	PlayerData[Player] = nil
end

local function IsInsideWhitelistedPart(RootPart)
	for _, Part in ipairs(Settings.Thresholds.MovementWhitelistParts) do
		if Part and Part:IsA("BasePart") then
			local Relative = Part.CFrame:PointToObjectSpace(RootPart.Position)
			local Half = Part.Size / 2

			if math.abs(Relative.X) <= Half.X
				and math.abs(Relative.Y) <= Half.Y
				and math.abs(Relative.Z) <= Half.Z then
				return true
			end
		end
	end

	return false
end

local function SetupPlayer(Player)
	Player.CharacterAdded:Connect(function()
		PlayerData[Player] = {
			BoostTime = 0,
			BoostPosition = nil,
			BoostWalkSpeed = 0,

			LastGrounded = tick(),
			LastPosition = nil
		}
	end)
end

Players.PlayerAdded:Connect(SetupPlayer)

for _, Player in ipairs(Players:GetPlayers()) do
	task.spawn(SetupPlayer, Player)
end

Players.PlayerRemoving:Connect(ResetPlayer)

RunService.Heartbeat:Connect(function()
	CurrentInterval += 1

	if CurrentInterval < FlySettings.Intervals then
		return
	end

	CurrentInterval = 0

	local Ignore = {}

	for _, Player in ipairs(Players:GetPlayers()) do
		if Player.Character then
			table.insert(Ignore, Player.Character)
		end
	end

	local RaycastParams = RaycastParams.new()
	RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
	RaycastParams.FilterDescendantsInstances = Ignore

	for _, Player in ipairs(Players:GetPlayers()) do
		local Data = PlayerData[Player]
		local Character = Player.Character

		if not Data or not Character then
			continue
		end

		local Humanoid = Character:FindFirstChildOfClass("Humanoid")
		local RootPart = Character:FindFirstChild("HumanoidRootPart")

		if not Humanoid or not RootPart or Humanoid.Health <= 0 then
			continue
		end

		local now = tick()

		if IsInsideWhitelistedPart(RootPart) then
			Data.BoostTime = now
			Data.BoostPosition = RootPart.Position
			Data.BoostWalkSpeed = Humanoid.WalkSpeed

			Data.LastGrounded = now
		end

		local InBoostGrace =
			(now - Data.BoostTime) <= MovementSettings.GraceTime

		local FoundGround = Workspace:Raycast(
			RootPart.Position,
			FlySettings.MaxDistanceFromGround,
			RaycastParams
		)

		local Velocity = RootPart.AssemblyLinearVelocity

		local HorizontalSpeed =
			Vector3.new(Velocity.X, 0, Velocity.Z).Magnitude

		local VerticalVelocity = Velocity.Y

		local IsFalling = VerticalVelocity < -2

		if FoundGround or IsFalling then
			Data.LastGrounded = now
			Data.LastPosition = RootPart.Position
			continue
		end

		local AirTime = now - Data.LastGrounded

		if AirTime < FlySettings.MaxAirTime then
			continue
		end

		local Detected = false

		if FlySettings.AddPlatformStandStrike
			and Humanoid:GetState() == Enum.HumanoidStateType.PlatformStanding then
			Detected = true
		end

		if HorizontalSpeed >= FlySettings.MinimumFlySpeed then
			Detected = true
		end

		if InBoostGrace and Data.BoostPosition then
			local Delta =
				Vector3.new(RootPart.Position.X, 0, RootPart.Position.Z)
			- Vector3.new(Data.BoostPosition.X, 0, Data.BoostPosition.Z)

			local Allowed =
				(Data.BoostWalkSpeed * (now - Data.BoostTime))
				+ MovementSettings.PositionTolerance

			if Delta.Magnitude > Allowed then
				Detected = true
			end
		end

		if Detected then
			if Data.LastPosition then
				RootPart.CFrame = CFrame.new(Data.LastPosition)
			end

			if Punish:AddDetection(Player, "AntiFly") then
				return
			end
		end
	end
end)

return AntiFly]]></ProtectedString>
					<string name="ScriptGuid">{EDA074C4-11D0-484F-B426-9CF15380BC29}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<string name="Name">AntiFly</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
				</Properties>
