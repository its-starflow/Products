			<Item class="ModuleScript" referent="RBX8AC0AFEF09AC4B74A790320343B0F742">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local AntiSpeed = {}

local Settings = require(script.Parent.Parent:WaitForChild("Settings"))

if not Settings.Enabled or not Settings.Detection.AntiSpeed then
	return AntiSpeed
end

local Players = game:GetService("Players")

local Punish = require(script.Parent.Parent:WaitForChild("Utils"):WaitForChild("Punish"))

local CharacterSettings = Settings.Thresholds.Character

local function IsWhitelistedSpeed(Speed)
	for _, Allowed in ipairs(CharacterSettings.WhitelistedWalkSpeeds) do
		if math.abs(Speed - Allowed) <= 0.1 then
			return true
		end
	end

	return false
end

local function SetupCharacter(Player, Character)
	local Humanoid = Character:WaitForChild("Humanoid", 10)

	if not Humanoid then
		return
	end

	Humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
		if Humanoid.Health <= 0 then
			return
		end

		local Speed = Humanoid.WalkSpeed

		if not IsWhitelistedSpeed(Speed) then
			if Punish:AddDetection(Player, "AntiSpeed") then
				return
			end
		end
	end)

	if not IsWhitelistedSpeed(Humanoid.WalkSpeed) then
		if Punish:AddDetection(Player, "AntiSpeed") then
			return
		end
	end
end

Players.PlayerAdded:Connect(function(Player)
	Player.CharacterAdded:Connect(function(Character)
		SetupCharacter(Player, Character)
	end)
end)

for _, Player in ipairs(Players:GetPlayers()) do
	if Player.Character then
		task.spawn(SetupCharacter, Player, Player.Character)
	end

	Player.CharacterAdded:Connect(function(Character)
		SetupCharacter(Player, Character)
	end)
end

return AntiSpeed]]></ProtectedString>
					<string name="ScriptGuid">{7BF9E5AC-181E-490C-86FD-95F34B869E29}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
