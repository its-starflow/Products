					<ProtectedString name="Source"><![CDATA[if not game:IsLoaded() then game.Loaded:Wait() end

local Event = game:GetService("ReplicatedStorage"):WaitForChild("VS-Remotes"):WaitForChild("NotifyEvent")

Event.OnClientEvent:Connect(function(title, text, dur)

	local ok, err = pcall(function()
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = tostring(title or "Notification"),
			Text = tostring(text or ""),
			Duration = tonumber(dur) or 3
		})
	end)

	if not ok then
		warn("[Notify System Failed]:", err)
	end
end)]]></ProtectedString>
